# Copy this file to .env and fill local secrets.

ENNOIA_NATURAL_EDIT_ENDPOINT=https://api.ennoia.so/api/preset/v2/chat/completions
ENNOIA_NATURAL_EDIT_HASH=<editAgentHash>
ENNOIA_NATURAL_EDIT_TIMEOUT_MS=60000
ENNOIA_NATURAL_EDIT_CHAT_WAIT_MS=60000
ENNOIA_NATURAL_EDIT_LOCAL_SEARCH_BUDGET_MS=1000
# Required when the natural edit preset has MCP tools attached.
# Prefer the user id that owns the Ennoia Studio MCP connection, or provide the exact x-mcp-<serverAlias>-authorization header.
ENNOIA_NATURAL_EDIT_USER_ID=
ENNOIA_NATURAL_EDIT_MCP_AUTHORIZATION_HEADER=
ENNOIA_NATURAL_EDIT_MCP_AUTHORIZATION=
# Example dynamic header: ENNOIA_MCP_KTO_AUTHORIZATION becomes x-mcp-kto-authorization.
# ENNOIA_MCP_KTO_AUTHORIZATION=
ENNOIA_TRIP_GENERATION_ENDPOINT=https://api.ennoia.so/api/preset/v2/chat/completions
ENNOIA_TRIP_GENERATION_HASH=<tripAgentHash>
ENNOIA_TRIP_GENERATION_TIMEOUT_MS=60000
ENNOIA_PROJECT_ID=KNTO-PROMPTON-2026-544
ENNOIA_API_KEY=

KTO_SERVICE_KEY=
KAKAO_REST_API_KEY=
LIVE_WEATHER=0

PORT=8787
STATE_FILE=
DISABLE_FILE_STORE=0
